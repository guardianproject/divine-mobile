# Zendesk Support SDK Credentials
# Get these from: https://rabblelabs.zendesk.com/admin → Channels → Mobile SDK
#
# IMPORTANT: Use Mobile SDK credentials (NOT OAuth Clients)
# OAuth is for authenticated users - we need anonymous ticket submission
#
# In Zendesk Admin:
# 1. Go to: Admin → Channels → Mobile SDK
# 2. Click "Add mobile SDK app" if you haven't already
# 3. Copy the "Application ID" → ZENDESK_APP_ID
# 4. The clientId can be any string identifier for your app → ZENDESK_CLIENT_ID
#
ZENDESK_APP_ID=         # Zendesk Mobile SDK "Application ID"
ZENDESK_CLIENT_ID=      # App identifier (e.g., "divine.video" or "openvine-mobile")
ZENDESK_URL=https://rabblelabs.zendesk.com

# Zendesk REST API Token (for fallback bug reports on macOS/Windows/Web)
# Get from: Admin → Apps and integrations → APIs → Zendesk API → Add API token
ZENDESK_API_TOKEN=      # API token for REST API fallback

# Default environment for fresh installs (PRODUCTION, PRODUCTION_NEW, STAGING, DEV)
# If not set, defaults to PRODUCTION
# DEFAULT_ENV=PRODUCTION

# ProofSign C2PA Signing (ask nathan@proofmode.org for access)
# PROOFSIGN_SERVER_URL is required for C2PA content credential signing.
# Device auth (App Attest / Play Integrity) is used automatically.
# Set PROOFSIGN_BEARER_TOKEN for dev/CI to bypass device attestation.
PROOFSIGN_SERVER_URL=
PROOFSIGN_GCP_PROJECT_NUMBER=
PROOFSIGN_APPLE_APP_ID=
PROOFSIGN_BEARER_TOKEN=

